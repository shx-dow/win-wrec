---
import { Font } from "astro:assets";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/wrec.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-clash-grotesk" preload />
    <script>
      import { configure } from "onedollarstats";

      configure();
    </script>
    <title>wrec</title>
  </head>
  <body class="m-0 overflow-hidden bg-white text-neutral-950 select-none">
    <main class="grid h-dvh place-items-center" aria-label="wrec">
      <div class="relative flex flex-col items-start">
        <div
          class="inline-flex items-baseline gap-0 font-[family-name:var(--font-clash-grotesk)] text-[4.75rem] leading-[0.9] font-black tracking-normal md:text-[9rem]"
        >
          <h1 class="m-0">wrec</h1>
          <div
            class="animate-recording-blink h-4 w-4 rounded-full text-[#c62828]"
            aria-hidden="true"
          >
            .
          </div>
        </div>
        <a
          href="/docs"
          class="mt-1 ml-1 font-[family-name:var(--font-clash-grotesk)] text-2xl leading-none font-normal tracking-normal text-black no-underline md:mt-2 md:text-3xl"
        >
          docs
        </a>
      </div>
    </main>
  </body>
</html>
